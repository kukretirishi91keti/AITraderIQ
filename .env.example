# TraderAI Pro - Environment Configuration
# Copy this file to backend/.env and fill in values

# ===== REQUIRED =====

# JWT secret key (MUST change for production!)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-in-production

# CORS origins (comma-separated, must match your frontend URL)
# Local dev:  http://localhost:5173,http://localhost:3000
# Railway:    https://your-frontend.up.railway.app
# Netlify:    https://your-app.netlify.app
# Render:     https://your-app.onrender.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== DATA MODE =====

# Demo mode (true = use simulated data as fallback, good for demos)
DEMO_MODE=true

# Database URL (SQLite for dev, PostgreSQL for production)
# Dev:  sqlite+aiosqlite:///./traderai.db
# Prod: postgresql+asyncpg://user:pass@host:5432/traderai
DATABASE_URL=sqlite+aiosqlite:///./traderai.db

# ===== AI / LLM =====

# Groq API key for AI trading assistant (free tier at console.groq.com)
# Without this, AI falls back to rule-based responses (still works!)
GROQ_API_KEY=

# ===== PAYMENTS — Stripe (International: USD, EUR, GBP) =====

# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Create products at https://dashboard.stripe.com/products
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# ===== PAYMENTS — Razorpay (India: INR) =====

# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Create plans at https://dashboard.razorpay.com/app/subscriptions/plans
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_PREMIUM=

# ===== RATE LIMITING =====

RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_QUOTE=30/minute
RATE_LIMIT_AI=10/minute
RATE_LIMIT_AUTH=5/minute

# ===== DEPLOYMENT =====

# Set by Railway/Render automatically, override for local dev
# PORT=8000
# HOST=0.0.0.0
