# TraderAI Pro - Environment Configuration
# Copy this file to .env and fill in values

# Demo mode (true = use simulated data as fallback)
DEMO_MODE=true

# LLM Provider API Keys (set any one — users can also add their own from UI)
# Groq: Get key at https://console.groq.com/keys
GROQ_API_KEY=
# OpenAI: Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic: Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# JWT secret key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=change-this-in-production

# Database URL (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./traderai.db

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_QUOTE=30/minute
RATE_LIMIT_AI=10/minute
RATE_LIMIT_AUTH=5/minute
